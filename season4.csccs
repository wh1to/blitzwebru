        var context = {
            "IS_CHINESE": false,
            "is_preview": false,
            "news_page": {
                "category": {
                    "important": false,
                    "lang": "ru",
                    "order": 0,
                    "slug": "updates",
                    "title": "\u041e\u0431\u043d\u043e\u0432\u043b\u0435\u043d\u0438\u044f"
                },
                "content": "\u003cdiv\u003e\n  \u003cblockquote class=\"message-block\"\u003e\u0417\u0430\u0433\u0440\u0443\u0436\u0430\u0439 \u043d\u043e\u0432\u0443\u044e \u0432\u0435\u0440\u0441\u0438\u044e \u0441 22 \u043c\u0430\u044f!\n  \u003c/blockquote\u003e\n  \u003ch2\u003e\n    \u0421\u0435\u0437\u043e\u043d 4: \u041f\u0440\u0430\u0437\u0434\u043d\u0438\u0447\u043d\u044b\u0439\n  \u003c/h2\u003e\n  \u003cp\u003e\u0412 \u044d\u0442\u043e\u0442 \u0440\u0430\u0437 \u2014 \u0431\u043e\u043b\u044c\u0448\u0435, \u0447\u0435\u043c \u0441\u0435\u0437\u043e\u043d\u043d\u043e\u0435 \u0441\u043e\u0431\u044b\u0442\u0438\u0435 \u0441 \u043a\u0440\u0430\u0441\u0438\u0432\u043e\u0439 \u0438\u0441\u0442\u043e\u0440\u0438\u0435\u0439. \u0422\u0440\u0438 \u043c\u0435\u0441\u044f\u0446\u0430 \u043c\u044b \u043d\u0430 \u0432\u0441\u0435 \u043b\u0430\u0434\u044b \u0431\u0443\u0434\u0435\u043c \u0442\u0440\u0430\u043d\u0441\u043b\u0438\u0440\u043e\u0432\u0430\u0442\u044c \u0434\u043b\u044f \u0442\u0435\u0431\u044f \u0432\u0435\u0441\u0435\u043b\u044c\u0435. \u0422\u0430\u043a \u0447\u0442\u043e \u043f\u0440\u0438\u0433\u043e\u0442\u043e\u0432\u044c\u0441\u044f \u043a \u0441\u0430\u043c\u043e\u043c\u0443 \u044f\u0440\u043a\u043e\u043c\u0443 \u0438 \u043d\u0430\u0441\u044b\u0449\u0435\u043d\u043d\u043e\u043c\u0443 \u043b\u0435\u0442\u0443 \u0432 \u0438\u0441\u0442\u043e\u0440\u0438\u0438 \u0438\u0433\u0440\u044b! \u0418 \u043f\u043e\u043c\u043d\u0438: \u0433\u0434\u0435 \u044d\u043a\u0440\u0430\u043d, \u0442\u0430\u043c \u0438 Blitz\u00a0\ud83d\ude09\n  \u003c/p\u003e\n  \u003ch3\u003e\u0422\u0430\u043d\u043a\u0438 \u043f\u0440\u043e\u0433\u0440\u0435\u0441\u0441\u0438\u0438: \u00ab\u0410 \u0447\u0442\u043e, \u0435\u0441\u043b\u0438?..\u00bb\n  \u003c/h3\u003e\n  \u003cp\u003e\u041d\u0430 \u0433\u043b\u0430\u0432\u043d\u043e\u043c \u044d\u043a\u0440\u0430\u043d\u0435 \u0421\u0435\u0437\u043e\u043d\u0430 \u0442\u0435\u0431\u044f \u0436\u0434\u0451\u0442 \u0446\u0435\u043f\u043e\u0447\u043a\u0430 \u044d\u0442\u0430\u043f\u043e\u0432 \u0441 \u043d\u0430\u0433\u0440\u0430\u0434\u0430\u043c\u0438. \u042d\u0442\u043e \u0442\u0440\u0438 \u0443\u043d\u0438\u043a\u0430\u043b\u044c\u043d\u044b\u0445 \u0442\u0430\u043d\u043a\u0430 VII, VIII \u0438 IX \u0443\u0440\u043e\u0432\u043d\u0435\u0439 \u0441\u043e \u043c\u043d\u043e\u0436\u0435\u0441\u0442\u0432\u043e\u043c \u0443\u043b\u0443\u0447\u0448\u0435\u043d\u0438\u0439. \u041a\u0430\u0436\u0434\u044b\u0439 \u0431\u0443\u0434\u0435\u0442 \u0441\u043e\u0431\u0440\u0430\u043d \u0432 \u0410\u043d\u0433\u0430\u0440\u0435 \u043d\u0430 \u0431\u0430\u0437\u0435  \u0440\u0435\u0441\u0443\u0440\u0441\u043e\u0432, \u043a\u043e\u0442\u043e\u0440\u044b\u0435 \u0442\u044b \u0440\u0430\u0437\u0434\u043e\u0431\u0443\u0434\u0435\u0448\u044c \u0437\u0430 \u0432\u0440\u0435\u043c\u044f \u043f\u0440\u0430\u0437\u0434\u043d\u0438\u0447\u043d\u043e\u0433\u043e \u0441\u0435\u0437\u043e\u043d\u0430. \n  \u003c/p\u003e\n  \u003cp\u003e\n    \u003cspan class=\"tanks-info tanks-info__collection\"\u003e\u003cspan class=\"tanks-info_flag tanks-info_flag__other\"\u003e\u003c/span\u003e \u003cspan class=\"tanks-info_type tanks-info_type__heavytank\"\u003e\u003c/span\u003e \u003cspan class=\"tanks-info_level\"\u003e\n      VII\n      \u003c/span\u003eE-10\u003c/span\u003e, \n    \u003cspan class=\"tanks-info tanks-info__collection\"\u003e\u003cspan class=\"tanks-info_flag tanks-info_flag__other\"\u003e\u003c/span\u003e \u003cspan class=\"tanks-info_type tanks-info_type__at-spg\"\u003e\u003c/span\u003e \u003cspan class=\"tanks-info_level\"\u003e\n      VIII\n      \u003c/span\u003eDTH-STR\u003c/span\u003e \u0438 \n    \u003cspan class=\"tanks-info tanks-info__collection\"\u003e\u003cspan class=\"tanks-info_flag tanks-info_flag__other\"\u003e\u003c/span\u003e \u003cspan class=\"tanks-info_type tanks-info_type__heavytank\"\u003e\u003c/span\u003e \u003cspan class=\"tanks-info_level\"\u003e\n      IX\n      \u003c/span\u003eKV-JR\u003c/span\u003e... \u043c\u0430\u0448\u0438\u043d\u044b \u0432\u044b\u0433\u043b\u044f\u0434\u044f\u0442 \u043e-\u043e-\u043e\u0447\u0435\u043d\u044c \u0437\u043d\u0430\u043a\u043e\u043c\u043e, \u0438 \u044d\u0442\u043e \u043d\u0435 \u0441\u043b\u0443\u0447\u0430\u0439\u043d\u043e\u0441\u0442\u044c! \u041c\u044b \u0432\u044b\u0431\u0440\u0430\u043b\u0438 \u0441\u0430\u043c\u044b\u0435 \u043b\u044e\u0431\u0438\u043c\u044b\u0435 \u0438\u0433\u0440\u043e\u043a\u0430\u043c\u0438 \u0442\u0430\u043d\u043a\u0438 \u0438 \u043f\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u0438\u043b\u0438, \u043a\u0430\u043a \u043e\u043d\u0438 \u043c\u043e\u0433\u0443\u0442 \u0437\u0430\u0438\u0433\u0440\u0430\u0442\u044c, \u043e\u043a\u0430\u0437\u0430\u0432\u0448\u0438\u0441\u044c \u043d\u0430 \u0434\u0440\u0443\u0433\u043e\u043c \u0443\u0440\u043e\u0432\u043d\u0435.\n  \u003c/p\u003e\n  \u003cgallery uuid=\"2f8e561e-7ef3-4e6e-9ff0-be2a2d1f6d0b\"\u003e\n    \u003cstrong class=\"not-rendered\"\u003efolder:2f8e561e-7ef3-4e6e-9ff0-be2a2d1f6d0b\u003c/strong\u003e\n  \u003c/gallery\u003e\n  \u003cp\u003e\u041f\u043e\u043b\u0443\u0447\u0430\u044f \n    \u003cspan style=\"white-space: nowrap\"\u003e\u003cimg src=\"//media-wbp.wgcdn.co/media/filer_public/images/season-4-prx.webp\" style=\"float: none;width: 25px; vertical-align: middle;\"\u003e\u00a0\u042d\u043a\u0440\u0430\u043d\u044b,\u003c/span\u003e \u0442\u044b \u0431\u0443\u0434\u0435\u0448\u044c \u043f\u043e\u0441\u0442\u0443\u043f\u0430\u0442\u0435\u043b\u044c\u043d\u043e \u0438\u0437\u0443\u0447\u0430\u0442\u044c \u0438 \u043f\u0440\u043e\u043a\u0430\u0447\u0438\u0432\u0430\u0442\u044c \u044d\u0442\u0438 \u0442\u0430\u043d\u043a\u0438.\n  \u003c/p\u003e\n  \u003cdetails\u003e\n    \u003csummary\u003e\u0413\u0434\u0435 \u0440\u0430\u0437\u0434\u043e\u0431\u044b\u0442\u044c \n      \u003cspan style=\"white-space: nowrap\"\u003e\u003cimg src=\"//media-wbp.wgcdn.co/media/filer_public/images/season-4-prx.webp\" style=\"float: none;width: 25px; vertical-align: middle;\"\u003e\u00a0\u042d\u043a\u0440\u0430\u043d\u044b?\u003c/span\u003e\n    \u003c/summary\u003e\n    \u003cul\u003e\n      \u003cli\u003e\u0441\u0440\u0435\u0434\u0438 \u043d\u0430\u0433\u0440\u0430\u0434 \u0411\u0430\u0437\u043e\u0432\u043e\u0433\u043e \u0438 \u041e\u0441\u043e\u0431\u043e\u0433\u043e \u043f\u0440\u043e\u043f\u0443\u0441\u043a\u043e\u0432 \u041e\u043f\u0435\u0440\u0430\u0446\u0438\u0439\n      \u003c/li\u003e \n      \u003cli\u003e\u0441\u0440\u0435\u0434\u0438 \u043d\u0430\u0433\u0440\u0430\u0434 \u0441\u043e\u0431\u044b\u0442\u0438\u0439\n      \u003c/li\u003e \n      \u003cli\u003e\u0432 \u0440\u0435\u0439\u0442\u0438\u043d\u0433\u043e\u0432\u044b\u0445 \u0431\u043e\u044f\u0445 \n      \u003c/li\u003e \n      \u003cli\u003e\u0432 \u0442\u0443\u0440\u043d\u0438\u0440\u0430\u0445\n      \u003c/li\u003e \n      \u003cli\u003e\u0432\u044b\u043f\u043e\u043b\u043d\u044f\u044f \u041a\u0432\u0435\u0441\u0442\u044b \u0438 \u041f\u0440\u0438\u043a\u0430\u0437\u044b\n      \u003c/li\u003e \n      \u003cli\u003e\u0432\u044b\u043f\u043e\u043b\u043d\u044f\u044f \u041a\u043b\u0430\u043d\u043e\u0432\u044b\u0435 \u0437\u0430\u0434\u0430\u0447\u0438\n      \u003c/li\u003e \n      \u003cli\u003e\u0438\u0433\u0440\u0430\u044f \u0432 \u0420\u043e\u0437\u044b\u0433\u0440\u044b\u0448\u0438\n      \u003c/li\u003e \n      \u003cli\u003e\u0432 \u0441\u043e\u0441\u0442\u0430\u0432\u0435 \u043d\u0430\u0431\u043e\u0440\u043e\u0432 \u0432 \u043c\u0430\u0433\u0430\u0437\u0438\u043d\u0435\n      \u003c/li\u003e\n    \u003c/ul\u003e\n  \u003c/details\u003e \n  \u003ch3\u003e\u0410\u043d\u0433\u0430\u0440\n  \u003c/h3\u003e\n  \u003cp\u003e\u0421\u043e \u0441\u0442\u0430\u0440\u0442\u043e\u043c \u0421\u0435\u0437\u043e\u043d\u0430 \u043e\u043d \u0441\u0442\u0430\u043d\u0435\u0442 \u0446\u0435\u043d\u0442\u0440\u043e\u043c \u043f\u0440\u0438\u0442\u044f\u0436\u0435\u043d\u0438\u044f \u0432\u0441\u0435\u0445 \u044d\u043c\u043e\u0446\u0438\u0439, \u043a\u0440\u043e\u043c\u0435 \u0441\u043a\u0443\u043a\u0438. \u0417\u0430 \u043e\u043a\u043d\u043e\u043c \u0434\u0438\u043a\u0430\u044f \u0441\u043c\u0435\u0441\u044c \u0438\u0437 \u043f\u0440\u043e\u0448\u043b\u043e\u0433\u043e, \u043d\u0430\u0441\u0442\u043e\u044f\u0449\u0435\u0433\u043e \u0438 \u0431\u0443\u0434\u0443\u0449\u0435\u0433\u043e \u2014 \u0443\u0433\u0430\u0434\u0430\u0439, \u0447\u0442\u043e \u043a \u0447\u0435\u043c\u0443! \u0410 \u0432\u043d\u0443\u0442\u0440\u0438? \u0422\u0443\u0442 \u043f\u0440\u0438\u043f\u0430\u0440\u043a\u043e\u0432\u0430\u043b\u0441\u044f \u0430\u0432\u0442\u043e\u0431\u0443\u0441 \u0442\u0443\u0441\u043e\u0432\u0449\u0438\u043a\u043e\u0432 (\u043d\u0430\u0436\u043c\u0438 \u043d\u0430 \u043d\u0435\u0433\u043e!), \u0430 \u043c\u0443\u0437\u044b\u043a\u0430\u043b\u044c\u043d\u0430\u044f \u0441\u0442\u0430\u043d\u0446\u0438\u044f \u0436\u0434\u0451\u0442, \u043f\u043e\u043a\u0430 \u0442\u044b \u0432\u044b\u0431\u0435\u0440\u0435\u0448\u044c \u0442\u0440\u0435\u043a \u043f\u043e\u0434 \u043d\u0430\u0441\u0442\u0440\u043e\u0435\u043d\u0438\u0435. \u0421\u0442\u0435\u043d\u0430 \u044d\u043a\u0440\u0430\u043d\u043e\u0432 \u2014 \u0435\u0449\u0451 \u043e\u0434\u043d\u0430 \u043f\u0440\u043e\u0433\u0440\u0435\u0441\u0441\u0438\u044f \u0421\u0435\u0437\u043e\u043d\u0430 \u2014 \u0431\u0443\u0434\u0435\u0442 \u0441\u0442\u0430\u043d\u043e\u0432\u0438\u0442\u044c\u0441\u044f \u0432\u0441\u0451 \u043d\u0430\u0441\u044b\u0449\u0435\u043d\u043d\u0435\u0435 \u0438 \u0438\u043d\u0442\u0435\u0440\u0435\u0441\u043d\u0435\u0435.\n  \u003c/p\u003e\n  \u003cp\u003e\n    \u003cgallery uuid=\"648a0cc3-e473-4a41-ac9f-f262f4fa8747\"\u003e\n      \u003cstrong class=\"not-rendered\"\u003efolder:648a0cc3-e473-4a41-ac9f-f262f4fa8747\u003c/strong\u003e\n    \u003c/gallery\u003e\n  \u003c/p\u003e\n  \u003ch2\u003e\u0418\u0442\u0430\u043b\u044c\u044f\u043d\u0441\u043a\u0438\u0435 \u0442\u044f\u0436\u0451\u043b\u044b\u0435 \u0442\u0430\u043d\u043a\u0438\n  \u003c/h2\u003e\n  \u003cp\u003e\u0412 \u0434\u0435\u0440\u0435\u0432\u0435 \u0438\u0442\u0430\u043b\u044c\u044f\u043d\u0441\u043a\u043e\u0439 \u0442\u0435\u0445\u043d\u0438\u043a\u0438 \u043f\u043e\u043f\u043e\u043b\u043d\u0435\u043d\u0438\u0435 \u2014 \u0447\u0435\u0442\u044b\u0440\u0435 \u0442\u044f\u0436\u0430. \u041c\u043e\u0431\u0438\u043b\u044c\u043d\u044b\u0435 \u0438 \u0442\u043e\u0447\u043d\u044b\u0435, \u043e\u043d\u0438 \u0438\u0434\u0435\u0430\u043b\u044c\u043d\u043e \u043f\u043e\u0434\u043e\u0439\u0434\u0443\u0442 \u0434\u043b\u044f \u0431\u043e\u044f \u043d\u0430 \u0432\u0442\u043e\u0440\u043e\u0439 \u043b\u0438\u043d\u0438\u0438. \u0413\u043b\u0430\u0432\u043d\u044b\u0435 \u043f\u0440\u0435\u0438\u043c\u0443\u0449\u0435\u0441\u0442\u0432\u0430 \u00ab\u0441\u0435\u043c\u0451\u0440\u043a\u0438\u00bb Carro D\u0027 Assalto P.88 \u0432 \u0446\u0438\u043a\u043b\u0438\u0447\u043d\u043e\u0439 \u043f\u0443\u0448\u043a\u0435 \u0438 \u043c\u0430\u043b\u043e\u043c \u0432\u0440\u0435\u043c\u0435\u043d\u0438 \u043f\u0435\u0440\u0435\u0437\u0430\u0440\u044f\u0434\u043a\u0438. \u0422\u0430\u043d\u043a\u0438 VIII \u0438\u00a0IX \u0443\u0440\u043e\u0432\u043d\u0435\u0439 Progetto CC55 mod. 54 \u0438 Progetto C50 mod. 66 \u043e\u0441\u043d\u0430\u0449\u0435\u043d\u044b \u0434\u0432\u0443\u0445\u0441\u043d\u0430\u0440\u044f\u0434\u043d\u044b\u043c \u0431\u0430\u0440\u0430\u0431\u0430\u043d\u043e\u043c, \u0447\u0442\u043e \u043f\u043e\u0437\u0432\u043e\u043b\u044f\u0435\u0442 \u043d\u0430\u043d\u043e\u0441\u0438\u0442\u044c \u043d\u0435\u043c\u0430\u043b\u044b\u0439 \u0443\u0440\u043e\u043d \u0437\u0430 \u0441\u0447\u0438\u0442\u0430\u043d\u043d\u044b\u0435 \u0441\u0435\u043a\u0443\u043d\u0434\u044b.\n  \u003c/p\u003e\n  \u003cp\u003e\u0412\u0435\u0440\u0448\u0438\u043d\u0430 \u0432\u0435\u0442\u043a\u0438 \u2014 \u043c\u043e\u0449\u043d\u044b\u0439 Rinoceronte \u0441 \u043c\u0430\u0433\u0430\u0437\u0438\u043d\u043e\u043c \u043d\u0430 2 \u0441\u043d\u0430\u0440\u044f\u0434\u0430. \u041f\u043e\u0434\u0432\u0438\u0436\u043d\u044b\u0439, \u043c\u0435\u0442\u043a\u0438\u0439, \u0441 \u043a\u043e\u043c\u0444\u043e\u0440\u0442\u043d\u043e\u0439 \u043f\u0443\u0448\u043a\u043e\u0439 \u0438 \u0431\u0440\u043e\u043d\u0438\u0440\u043e\u0432\u0430\u043d\u043d\u043e\u0439 \u0431\u0430\u0448\u043d\u0435\u0439, \u044d\u0442\u043e\u0442 \u0442\u044f\u0436 \u0440\u0430\u0441\u043f\u0440\u0430\u0432\u0438\u0442\u0441\u044f \u0441 \u043f\u0440\u043e\u0442\u0438\u0432\u043d\u0438\u043a\u0430\u043c\u0438 \u0432 \u043c\u0433\u043d\u043e\u0432\u0435\u043d\u044c\u0435 \u043e\u043a\u0430! \u041d\u043e \u0443\u0447\u0442\u0438: \u0438\u0433\u0440\u0430\u044f \u043e\u0442 \u0431\u0430\u0448\u043d\u0438, \u043d\u0435 \u0441\u0442\u043e\u0439 \u043d\u0430 \u043c\u0435\u0441\u0442\u0435, \u0447\u0442\u043e\u0431\u044b \u0442\u0435\u0431\u044f \u0435\u0449\u0451 \u0441\u043b\u043e\u0436\u043d\u0435\u0435 \u0431\u044b\u043b\u043e \u043f\u0440\u043e\u0431\u0438\u0442\u044c \u0432 \u0443\u044f\u0437\u0432\u0438\u043c\u044b\u0435 \u043c\u0435\u0441\u0442\u0430.\n  \u003c/p\u003e\n  \u003cgallery uuid=\"781da9a1-9dc6-4371-bddb-52d71e5bde91\"\u003e\n    \u003cstrong class=\"not-rendered\"\u003efolder:781da9a1-9dc6-4371-bddb-52d71e5bde91\u003c/strong\u003e\n  \u003c/gallery\u003e\n  \u003ch2\u003e\u0411\u0430\u043b\u0430\u043d\u0441\u043d\u044b\u0435 \u043f\u0440\u0430\u0432\u043a\u0438\n  \u003c/h2\u003e\n  \u003cp\u003e\u041c\u044b \u043f\u0435\u0440\u0435\u0441\u043c\u043e\u0442\u0440\u0435\u043b\u0438 \u0431\u0430\u043b\u0430\u043d\u0441\u00a0\u0441\u043d\u0430\u0440\u044f\u0436\u0435\u043d\u0438\u044f \u0438 \u043e\u0431\u043e\u0440\u0443\u0434\u043e\u0432\u0430\u043d\u0438\u044f. \u0421\u0430\u043c\u0438 \u043f\u043e \u0441\u0435\u0431\u0435 \u0438\u0437\u043c\u0435\u043d\u0435\u043d\u0438\u044f \u0441\u043e\u0432\u0441\u0435\u043c \u043d\u0435\u0431\u043e\u043b\u044c\u0448\u0438\u0435, \u043d\u043e \u043a\u0430\u0441\u0430\u044e\u0442\u0441\u044f \u0432\u0441\u0435\u0445 \u0442\u0430\u043d\u043a\u043e\u0432. \u0410 \u0437\u043d\u0430\u0447\u0438\u0442, \u0442\u0435\u0445\u043d\u0438\u043a\u0430 \u0437\u0430\u0438\u0433\u0440\u0430\u0435\u0442 \u043f\u043e-\u043d\u043e\u0432\u043e\u043c\u0443, \u0438 \u0441\u0432\u0435\u0436\u0438\u0435 \u044d\u043c\u043e\u0446\u0438\u0438 \u0433\u0430\u0440\u0430\u043d\u0442\u0438\u0440\u043e\u0432\u0430\u043d\u044b!\u00a0\n  \u003c/p\u003e\n  \u003cp\u003e\u0422\u0430\u043a\u0436\u0435 \u0438\u0437\u043c\u0435\u043d\u0438\u0442\u0441\u044f \u0441\u0445\u0435\u043c\u0430 \u0431\u0440\u043e\u043d\u0438\u0440\u043e\u0432\u0430\u043d\u0438\u044f \u0438 \u043d\u0435\u043a\u043e\u0442\u043e\u0440\u044b\u0435 \u043f\u0430\u0440\u0430\u043c\u0435\u0442\u0440\u044b \u0443 \u0418\u0421-3, CTA-1, T-32, T-44. \u0412\u0441\u0435 \u0446\u0438\u0444\u0440\u044b \u0438 \u043f\u043e\u0434\u0440\u043e\u0431\u043d\u043e\u0441\u0442\u0438 \u0442\u044b \u043d\u0430\u0439\u0434\u0451\u0448\u044c \n    \u003ca href=\"/news/updates/balance-changes-season-4/\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"client-link\"\u003e\u0437\u0434\u0435\u0441\u044c\u003c/a\u003e.\n  \u003c/p\u003e\n  \u003cp\u003e\u0412 \u043a\u043b\u0430\u0441\u0441 \u043a\u043e\u043b\u043b\u0435\u043a\u0446\u0438\u043e\u043d\u043d\u044b\u0445 \u0442\u0430\u043d\u043a\u043e\u0432 \u0438\u0437 \u043f\u0440\u0435\u043c\u0438\u0443\u043c \u043f\u0435\u0440\u0435\u0432\u0435\u0434\u0435\u043d\u044b:\n  \u003c/p\u003e\n  \u003cul style=\"display: inline-block; margin: 0px 10px; vertical-align: top;\"\u003e\n    \u003cli\u003eBofors Tornvagn\n    \u003c/li\u003e\n    \u003cli\u003eSomua SM\n    \u003c/li\u003e\n    \u003cli\u003eM48A2 R\u00e4umpanzer\n    \u003c/li\u003e\n    \u003cli\u003eGSOR 1008\n    \u003c/li\u003e\n    \u003cli\u003eStrv 81\n    \u003c/li\u003e\n    \u003cli\u003eCenturion Mk. 5/1 RAAC\n    \u003c/li\u003e\n    \u003cli\u003eTitan-54d\n    \u003c/li\u003e\n    \u003cli\u003eM4A1 Revaloris\u00e9\n    \u003c/li\u003e\n    \u003cli\u00