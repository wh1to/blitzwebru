43c\u0435\u043b\u044c\u0441\u0434\u043e\u0440\u0444\n    \u003c/li\u003e\n    \u003cli\u003e\u042e\u043a\u043e\u043d\n    \u003c/li\u003e\n    \u003cli\u003e\u0424\u0430\u0443\u0441\u0442\n    \u003c/li\u003e\n    \u003cli\u003e\u041d\u044c\u044e-\u0411\u044d\u0439\n    \u003c/li\u003e\n  \u003c/ul\u003e\n  \u003cp\u003e\u0418\u00a0\u0432\u043e\u0437\u0432\u0440\u0430\u0449\u0430\u044e\u0442\u0441\u044f:\n  \u003c/p\u003e\n  \u003cul\u003e\n    \u003cli\u003e\u041f\u0440\u043e\u0442\u043e\u043a\u0430\n    \u003c/li\u003e\n    \u003cli\u003e\u0413\u043e\u0440\u044f\u0449\u0438\u0435 \u043f\u0435\u0441\u043a\u0438\n    \u003c/li\u003e\n    \u003cli\u003e\u041a\u0430\u043d\u044c\u043e\u043d\n    \u003c/li\u003e\n    \u003cli\u003e\u041c\u043e\u0440\u0441\u043a\u043e\u0439 \u0440\u0443\u0431\u0435\u0436\n    \u003c/li\u003e\n    \u003cli\u003e\u042d\u043b\u043b\u0430\u0434\u0430\n    \u003c/li\u003e\n  \u003c/ul\u003e\n  \u003ch2\u003e\u0420\u043e\u0442\u0430\u0446\u0438\u044f \u043a\u0430\u043c\u0443\u0444\u043b\u044f\u0436\u0430\n  \u003c/h2\u003e\n  \u003cp\u003e\n    \u0412 \u043c\u0435\u043d\u044e \u0443\u0441\u0442\u0430\u043d\u043e\u0432\u043a\u0438 \u043a\u0430\u043c\u0443\u0444\u043b\u044f\u0436\u0430 \u043f\u043e\u044f\u0432\u0438\u043b\u0438\u0441\u044c:\n  \u003c/p\u003e\n  \u003cul\u003e\n    \u003cli\u003e\u00ab\u0421\u0442\u0440\u0430\u043d\u043d\u0438\u043a \u043f\u0435\u0441\u043a\u043e\u0432\u00bb \u0434\u043b\u044f BZ-75\n    \u003c/li\u003e\n    \u003cli\u003eNeon Wild \u0434\u043b\u044f WZ-121\n    \u003c/li\u003e\n  \u003c/ul\u003e\n  \u003cp\u003e\n    \u003cgallery uuid=\"2aaf8f32-bcfb-44e0-9793-73a6a5602ecb\"\u003e\n      \u003cstrong class=\"not-rendered\"\u003efolder:2aaf8f32-bcfb-44e0-9793-73a6a5602ecb\u003c/strong\u003e\n    \u003c/gallery\u003e\n  \u003c/p\u003e\n \u003cp\u003e\u041f\u0440\u0435\u0434\u043b\u043e\u0436\u0435\u043d\u0438\u044f \u043a\u0443\u043f\u0438\u0442\u044c \u043b\u0435\u0433\u0435\u043d\u0434\u0430\u0440\u043d\u044b\u0435 \u043d\u043e\u0432\u0438\u043d\u043a\u0438 \u043f\u043e\u043b\u0443\u0447\u0430\u0442 \u0432\u043b\u0430\u0434\u0435\u043b\u044c\u0446\u044b \u043d\u0435\u0441\u043a\u043e\u043b\u044c\u043a\u0438\u0445 \u0442\u0430\u043d\u043a\u043e\u0432:\n\u003c/p\u003e\n\u003cul\u003e\n  \u003cli\u003e\u00ab\u0417\u0430\u043f\u0430\u043b\u00bb \u0434\u043b\u044f\u00a0Rinoceronte\n  \u003c/li\u003e\n  \u003cli\u003e\u00ab\u0427\u0438\u0441\u0442\u0438\u043b\u044c\u0449\u0438\u043a\u00bb \u0434\u043b\u044f\u00a0Chieftain Mk. 6\n  \u003c/li\u003e\n\u003c/ul\u003e\n  \u003cp\u003e\n    \u003cgallery uuid=\"2273a15b-2a15-48ac-b44a-efabdfe2a3fb\"\u003e\n      \u003cstrong class=\"not-rendered\"\u003efolder:2273a15b-2a15-48ac-b44a-efabdfe2a3fb\u003c/strong\u003e\n    \u003c/gallery\u003e\n  \u003c/p\u003e\n  \u003ch2\u003e\u0414\u043e\u0440\u0430\u0431\u043e\u0442\u043a\u0438 \u0438 \u0438\u0441\u043f\u0440\u0430\u0432\u043b\u0435\u043d\u043d\u044b\u0435 \u043e\u0448\u0438\u0431\u043a\u0438\n  \u003c/h2\u003e\n  \u003cul\u003e\n    \u003cli\u003eiOS: \u043f\u0440\u0435\u043a\u0440\u0430\u0449\u0435\u043d\u0430 \u043f\u043e\u0434\u0434\u0435\u0440\u0436\u043a\u0430 \u0443\u0441\u0442\u0440\u043e\u0439\u0441\u0442\u0432 \u0441 iOS 11. \u0427\u0442\u043e\u0431\u044b \u043f\u0440\u043e\u0434\u043e\u043b\u0436\u0438\u0442\u044c \u0438\u0433\u0440\u0430\u0442\u044c, \u043e\u0431\u043d\u043e\u0432\u0438 \u0443\u0441\u0442\u0440\u043e\u0439\u0441\u0442\u0432\u043e \u0434\u043e \u0432\u0435\u0440\u0441\u0438\u0438 iOS 12 \u0438\u043b\u0438 \u0432\u044b\u0448\u0435.\n      \u003cbr\u003e\n    \u003c/li\u003e\n    \u003cli\u003e\u0418\u0441\u043f\u0440\u0430\u0432\u043b\u0435\u043d\u044b \u0437\u0430\u0441\u0442\u0440\u0435\u0432\u0430\u043d\u0438\u044f, \u043f\u043e\u0434\u043f\u0440\u0430\u0432\u043b\u0435\u043d\u044b \u043c\u043e\u0434\u0435\u043b\u0438 \u0437\u0434\u0430\u043d\u0438\u0439 \u0438 \u043e\u0431\u044a\u0435\u043a\u0442\u043e\u0432 \u043d\u0430 \u043d\u0435\u043a\u043e\u0442\u043e\u0440\u044b\u0445 \u043a\u0430\u0440\u0442\u0430\u0445.\n    \u003c/li\u003e\n    \u003cli\u003e\u0414\u043e\u0440\u0430\u0431\u043e\u0442\u0430\u043d\u044b \u0440\u0430\u0437\u043b\u0438\u0447\u043d\u044b\u0435 \u044d\u043a\u0440\u0430\u043d\u044b, \u043e\u043f\u0438\u0441\u0430\u043d\u0438\u044f \u0438 \u0443\u0432\u0435\u0434\u043e\u043c\u043b\u0435\u043d\u0438\u044f.\n    \u003c/li\u003e\n    \u003cli\u003e\u0418\u0441\u043f\u0440\u0430\u0432\u043b\u0435\u043d\u044b \u043e\u0431\u0449\u0438\u0435 \u043e\u0448\u0438\u0431\u043a\u0438 \u0438 \u0440\u0435\u0448\u0435\u043d\u044b \u043f\u0440\u043e\u0431\u043b\u0435\u043c\u044b \u0441 \u043f\u0430\u0434\u0435\u043d\u0438\u0435\u043c \u043a\u043b\u0438\u0435\u043d\u0442\u0430.\n    \u003c/li\u003e\n  \u003c/ul\u003e\n\u003c/div\u003e",
